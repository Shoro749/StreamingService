@{
    Layout = "~/Views/Shared/Layouts/_SettingsLayout.cshtml";
    ViewData["Title"] = "Підключені пристрої";
}

<div class="flex flex-col gap-10 max-w-3xl">

    <div class="flex flex-col gap-4 text-white/60 text-sm leading-relaxed">
        <p>
            Тут відображаються усі пристрої, на яких ви входили до свого акаунта Lumeo.
            Ви можете завершити сеанс на будь-якому з них або вийти одразу з усіх, якщо
            помітили підозрілу активність.
        </p>
        <p>
            Якщо бачите невідомий пристрій — <span class="font-bold text-white/80">негайно завершіть сеанс і змініть пароль</span>,
            щоб убезпечити свій акаунт.
        </p>
    </div>

    <div>
        <h3 class="text-lg font-bold text-white font-montserrat mb-5">Поточний пристрій</h3>
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
            </div>
            <div class="flex flex-col">
                <span class="text-white font-medium">Windows — Chrome</span>
                <span class="text-white/50 text-sm">Кельн, Німеччина</span>
            </div>
        </div>
    </div>

    <div>
        <h3 class="text-lg font-bold text-white font-montserrat mb-5">Інші пристрої</h3>
        <div class="flex flex-col">

            <div class="flex items-center gap-4 py-4 border-b border-white/10">
                <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                    </svg>
                </div>
                <div class="flex flex-col">
                    <span class="text-white font-medium">Android — Lumeo App</span>
                    <span class="text-white/50 text-sm">Кельн, Німеччина — 2 години тому</span>
                </div>
                <button class="ml-auto p-2 text-white/50 hover:text-white transition-colors" aria-label="Видалити пристрій">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <div class="flex items-center gap-4 py-4 border-b border-white/10">
                <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                </div>
                <div class="flex flex-col">
                    <span class="text-white font-medium">MacOS — Safari</span>
                    <span class="text-white/50 text-sm">Кельн, Німеччина — 1 день тому</span>
                </div>
                <button class="ml-auto p-2 text-white/50 hover:text-white transition-colors" aria-label="Видалити пристрій">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

        </div>
    </div>

    <div class="flex flex-col gap-4 mt-2">
        <h3 class="text-lg font-bold text-white font-montserrat">Вийти на всіх пристроях</h3>
        <div class="flex flex-col gap-2 text-white/50 text-sm leading-relaxed max-w-xl">
            <p>Завершіть усі активні сеанси. Вам потрібно буде знову виконати вхід на кожному пристрої.</p>
            <p>Рекомендується, якщо ви втратили телефон або помітили підозрілі входи.</p>
        </div>
        <button class="self-start mt-2 px-6 py-2 bg-[#3D1A22] border border-[#7D2A39] hover:bg-[#4D1A22] rounded-lg text-[#E57373] transition-colors text-sm font-medium">
            Вийти на всіх пристроях
        </button>
    </div>

</div>