@using StreamingService.DTO.ViewModels.Account
@model ChangePasswordViewModel

@{
    Layout = "~/Views/Shared/Layouts/_SettingsLayout.cshtml";
    ViewData["Title"] = "Зміна пароля";
}

<div class="flex flex-col gap-8 max-w-3xl mt-4">

    <form asp-action="EditPassword" method="post" class="flex flex-col gap-10">
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

        <div class="shadow-glass bg-white/5 rounded-md p-8 flex flex-col gap-8">

            <div class="flex flex-col gap-2 relative">
                <label asp-for="CurrentPassword" class="text-white/70 text-sm font-semibold font-montserrat">Поточний пароль <span class="text-[#DCF260]">*</span></label>
                <div class="relative">
                    <input asp-for="CurrentPassword" type="password" id="currentPassword"
                           class="w-full bg-[#22223A]/50 border border-white/10 rounded-sm px-4 py-3 text-white focus:border-[#DCF260] outline-none transition-colors pr-12"
                           placeholder="Введіть поточний пароль">

                    <button type="button" onclick="togglePassword('currentPassword', 'eyeOpenCurrent', 'eyeClosedCurrent')" class="absolute inset-y-0 right-0 px-4 flex items-center text-white/50 hover:text-[#DCF260] transition-colors focus:outline-none">
                        <svg id="eyeClosedCurrent" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path>
                        </svg>
                        <svg id="eyeOpenCurrent" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="CurrentPassword" class="text-[#FF0000] text-xs absolute -bottom-5 left-0"></span>
            </div>

            <div class="flex flex-col gap-2 relative">
                <label asp-for="NewPassword" class="text-white/70 text-sm font-semibold font-montserrat">Новий пароль <span class="text-[#DCF260]">*</span></label>
                <div class="relative">
                    <input asp-for="NewPassword" type="password" id="newPassword"
                           class="w-full bg-[#22223A]/50 border border-white/10 rounded-sm px-4 py-3 text-white focus:border-[#DCF260] outline-none transition-colors pr-12"
                           placeholder="Введіть новий пароль">

                    <button type="button" onclick="togglePassword('newPassword', 'eyeOpenNew', 'eyeClosedNew')" class="absolute inset-y-0 right-0 px-4 flex items-center text-white/50 hover:text-[#DCF260] transition-colors focus:outline-none">
                        <svg id="eyeClosedNew" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path>
                        </svg>
                        <svg id="eyeOpenNew" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="text-[#FF0000] text-xs absolute -bottom-5 left-0"></span>

                <p class="text-white/40 text-xs mt-2 leading-relaxed">
                    Пароль має містити щонайменше 10 символів і не більш ніж 4 однакові символи поспіль.
                </p>
            </div>

        </div>

        <div class="flex flex-col gap-4">
            <p class="text-[#D3D3D3]/70 text-xs">* Обов'язкове поле.</p>

            <div class="flex flex-col-reverse sm:flex-row gap-4 pt-2">
                <a href="@Url.Action("Profile", "Settings", new { returnUrl = ViewBag.ReturnUrl })" class="shadow-glass flex-1 sm:flex-none px-8 py-3 bg-white/5 hover:bg-white/10 rounded-sm text-white font-semibold text-sm transition-colors text-center">
                    Скасувати
                </a>
                <button type="submit" class="shadow-glass flex-1 sm:flex-none px-8 py-3 bg-[#DCF260] hover:bg-[#c5dd4b] rounded-sm text-[#22223A] font-bold text-sm transition-colors">
                    Зберегти
                </button>
            </div>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/auth.js" asp-append-version="true"></script>
}