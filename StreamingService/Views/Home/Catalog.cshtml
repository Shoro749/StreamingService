@using StreamingService.DTO.Enums
@using StreamingService.Extensions
@using System.Diagnostics.Metrics
@{
    Layout = "~/Views/Shared/Layouts/_LayoutApp.cshtml";
}

<section class="relative w-full h-[580px] overflow-hidden mb-10">

    @await Component.InvokeAsync("Hero")

</section>

<section class="mb-12 relative group">

    <div id="genresList" class="fade-mask-right flex items-center gap-5 overflow-x-auto custom-scrollbar-hide pr-56 snap-x scroll-smooth">

        @foreach (VideoGenre genre in Enum.GetValues(typeof(VideoGenre)))
        {
            <button class="snap-start flex-shrink-0 px-9 py-3 rounded-full bg-white/10 backdrop-blur-sm
                               text-white font-medium text-base shadow-glass transition-all hover:bg-white/20 active:scale-95">
                @genre.GetDisplayName()
            </button>
        }
    </div>

    <div class="absolute right-0 top-1/2 -translate-y-1/2 z-20 flex items-center gap-2 pointer-events-none">

        <partial name="Partials/UI/_NavButton" model="@(new { Id = "genresLeftBtn", IsLeft = true, Theme = "glass"})" />
        <partial name="Partials/UI/_NavButton" model="@(new { Id = "genresRightBtn", IsLeft = false, Theme = "glass"})"/>

    </div>

</section>

