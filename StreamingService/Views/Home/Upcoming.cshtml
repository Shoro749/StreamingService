@using StreamingService.DTO.Enums
@using StreamingService.Extensions
@model Dictionary<string, List<StreamingService.DTO.ViewModels.VideoCardViewModel>>
@{
    Layout = "~/Views/Shared/Layouts/_LayoutApp.cshtml";
}

<div class="mt-11 relative z-20">
    <h1 class="text-5xl font-bold leading-none flex items-center gap-4 text-white">
        Незабаром в

        <div class="relative inline-block" id="countryDropdownContainer">
            <button id="countryBtn" class="text-[#0059FF] underline decoration-solid underline-offset-4 hover:text-blue-500 transition-colors flex items-center gap-3 cursor-pointer">
                <span id="selectedCountryText">@Country.Ukraine.GetShortName()</span>

                <svg class="w-4 h-2 transition-transform duration-300" id="countryArrow" viewBox="0 0 13 7" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1L6.5 6L12 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </button>

            <div id="countryMenu" class="hidden absolute top-[120%] left-1/2 -translate-x-1/2 w-56 py-3 bg-[#1E1E2F]/90 backdrop-blur-xl rounded-2xl shadow-glass transform origin-top transition-all">
                <ul class="flex flex-col text-center text-white/90 font-medium text-lg overflow-y-auto max-h-64 custom-scrollbar-hide">
                    @foreach (Country country in Enum.GetValues(typeof(Country)))
                    {
                        <li>
                            <button class="w-full py-2 hover:bg-white/10 hover:text-white transition-colors country-option"
                                    data-locative="@country.GetShortName()">
                                @country.GetDisplayName()
                            </button>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </h1>
</div>

<div class="relative mt-10 w-full relative pb-20">

    @if (Model != null && Model.Any())
    {
        @foreach (var group in Model)
        {
            <div class="mb-10">
                <h2 class="text-white font-montserrat font-medium text-3xl leading-none mb-4">
                    @group.Key
                </h2>

                <div class="flex flex-col gap-4">
                    @foreach (var video in group.Value)
                    {
                        <partial name="Partials/UI/_UpcomingRowCard" model="video" />
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="flex justify-center items-center py-20">
            <p class="text-white/50 text-xl font-montserrat">Немає інформації про майбутні релізи.</p>
        </div>
    }

</div>

@section Scripts {
    <script src="~/js/country.js" asp-append-version="true"></script>
}