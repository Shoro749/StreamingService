@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Ласкаво просимо";
}

<section id="hero-section" class="relative h-screen w-full flex items-center justify-center bg-cover bg-center bg-no-repeat overflow-hidden"
         style="background-image: url('/images/landing/Landing_robot.png'); transition: background-image 1s ease-in-out;">

    <div class="absolute inset-0 bg-black/10 z-0"></div>

    <div class="relative z-10 w-full max-w-4xl px-6 text-center flex flex-col items-center gap-6">

        <h1 class="text-4xl md:text-5xl lg:text-5xl font-black text-white leading-tight drop-shadow-lg">
            Безлімітні фільми, серіали та мультфільми — у будь-який час
        </h1>

        <p class="text-lg md:text-2xl font-normal font-montserrat text-white drop-shadow-md">
            Почни від ₴249/міс. Скасувати можна будь-коли.
        </p>

        <p class="text-base md:text-xl font-light font-montserrat text-white mt-16 drop-shadow-md max-w-[762px]">
            Готовий(-а) до перегляду? Введи свою електронну пошту, щоб створити або відновити акаунт.
        </p>

        <form action="/Account/Register" method="get" class="w-full max-w-5xl relative">

            <div class="relative w-full max-w-3xl mx-auto">

                <input type="email"
                       placeholder="Email address"
                       class="w-full h-20 pl-6 pr-52 rounded-2xl bg-[#9A9A9A]/10 text-white placeholder-gray-300 backdrop-blur-sm focus:outline-none focus:border-[#DCF260] focus:bg-black/40 transition-all text-xl font-normal shadow-glass"
                       required />

                <button type="submit" class="absolute right-0 top-0 h-20 w-48 bg-[#DCF260] rounded-2xl text-[#22223A] text-xl font-black uppercase flex items-center justify-center gap-3 hover:scale-105 transition-all duration-300 shadow-[0px_0px_10px_rgba(208,242,96,0.6)] z-10">
                    <span>Почати</span>

                    <img src="~/images/ui/symbols/vector_right.svg"
                         alt="Start"
                         class="w-2 h-4 object-contain" />
                </button>

            </div>

        </form>

    </div>

    <div class="absolute bottom-12 left-0 w-full flex justify-center items-center gap-4 z-20">

        <div id="slide-0" class="flex flex-col items-center gap-2 cursor-pointer group" onclick="setSlide(0)">
            <div class="w-4 h-4 bg-[#DCF260] rounded-full shadow-[0_0_10px_#DCF260] transition-all"></div>
            <div class="w-28 h-0.5 bg-[#DCF260] rounded-full transition-all"></div>
        </div>

        <div id="slide-1" class="flex flex-col items-center gap-2 cursor-pointer group opacity-50 hover:opacity-100 transition-opacity" onclick="setSlide(1)">
            <div class="w-2.5 h-2.5 bg-white rounded-full transition-all"></div>
            <div class="w-28 h-0.5 bg-white rounded-full transition-all"></div>
        </div>

        <div id="slide-2" class="flex flex-col items-center gap-2 cursor-pointer group opacity-50 hover:opacity-100 transition-opacity" onclick="setSlide(2)">
            <div class="w-2.5 h-2.5 bg-white rounded-full transition-all"></div>
            <div class="w-28 h-0.5 bg-white rounded-full transition-all"></div>
        </div>

    </div>

</section>

