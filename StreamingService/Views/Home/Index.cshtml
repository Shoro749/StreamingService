@model StreamingService.DTO.ViewModels.HomePageViewModel
@{
    Layout = "~/Views/Shared/Layouts/_LayoutLanding.cshtml"; ;
    ViewData["Title"] = "Ласкаво просимо";
}

<section id="hero-section" class="relative h-screen w-full flex items-center justify-center bg-cover bg-center bg-no-repeat overflow-hidden"
         style="background-image: url('/images/landing/Landing_robot.png'); transition: background-image 1s ease-in-out;">

    <div class="absolute inset-0 bg-black/10 z-0"></div>

    <div class="relative z-10 w-full max-w-4xl px-6 text-center flex flex-col items-center gap-6">

        <h1 class="text-4xl md:text-5xl lg:text-5xl font-black text-white leading-tight drop-shadow-lg">
            Безлімітні фільми, серіали та мультфільми — у будь-який час
        </h1>

        <p class="text-lg md:text-2xl font-normal font-montserrat text-white drop-shadow-md">
            Почни від ₴249/міс. Скасувати можна будь-коли.
        </p>

        <p class="text-base md:text-xl font-light font-montserrat text-white mt-16 drop-shadow-md max-w-[762px]">
            Готовий(-а) до перегляду? Введи свою електронну пошту, щоб створити або відновити акаунт.
        </p>

        <form asp-controller="Account" asp-action="Register" method="get" class="w-full max-w-5xl relative">

            <div class="relative w-full max-w-3xl mx-auto">

                <input name="Email"
                       type="email"
                       placeholder="Email address"
                       class="w-full h-20 pl-6 pr-52 rounded-2xl bg-[#9A9A9A]/10 text-white placeholder-gray-300 backdrop-blur-sm focus:outline-none focus:border-[#DCF260] focus:bg-black/40 transition-all text-xl font-normal shadow-glass"
                       required />

                <button type="submit" class="absolute right-0 top-0 h-20 w-48 bg-[#DCF260] rounded-2xl text-[#22223A] text-xl font-black uppercase flex items-center justify-center gap-3 hover:scale-105 transition-all duration-300 shadow-[0px_0px_10px_rgba(208,242,96,0.6)] z-10">
                    <span>Почати</span>

                    <img src="~/images/ui/symbols/vector_right.svg"
                         alt="Start"
                         class="w-2 h-4 object-contain" />
                </button>

            </div>

        </form>

    </div>

    <div class="absolute bottom-12 left-0 w-full flex justify-center items-center gap-4 z-20">

        <div id="slide-0" class="flex flex-col items-center gap-2 cursor-pointer group" onclick="setSlide(0)">
            <div class="w-4 h-4 bg-[#DCF260] rounded-full shadow-[0_0_10px_#DCF260] transition-all"></div>
            <div class="w-28 h-0.5 bg-[#DCF260] rounded-full transition-all"></div>
        </div>

        <div id="slide-1" class="flex flex-col items-center gap-2 cursor-pointer group opacity-50 hover:opacity-100 transition-opacity" onclick="setSlide(1)">
            <div class="w-2.5 h-2.5 bg-white rounded-full transition-all"></div>
            <div class="w-28 h-0.5 bg-white rounded-full transition-all"></div>
        </div>

        <div id="slide-2" class="flex flex-col items-center gap-2 cursor-pointer group opacity-50 hover:opacity-100 transition-opacity" onclick="setSlide(2)">
            <div class="w-2.5 h-2.5 bg-white rounded-full transition-all"></div>
            <div class="w-28 h-0.5 bg-white rounded-full transition-all"></div>
        </div>

    </div>

</section>

<section class="relative w-full min-h-screen flex flex-col items-center justify-center overflow-hidden pb-20">
         
    <h2 class="text-6xl md:text-10xl font-black text-white text-center leading-none mt-16 drop-shadow-md">
        Обери тариф
    </h2>

    <div class="lumeo-container grid grid-cols-1 xl:grid-cols-3 gap-5 items-start -mt-12 mb-12 z-10">
       
        @foreach (var tier in Model.PricingTiers)
        {
            <partial name="~/Views/Shared/Partials/Landing/_PriceCard.cshtml" 
                     model="tier"
                     view-data='@new ViewDataDictionary(ViewData) { { "TargetAction", "Register" } }' />
        }
   
    </div>

    <div class="lumeo-container">
		<p class="w-full text-xl font-normal font-montserrat text-white/50 text-left">
			**Усі тарифні плани можуть містити рекламу перед або після показу контенту, а також у спеціальних подіях.
			Якість відео та звуку залежить від швидкості інтернет-з'єднання, технічних можливостей пристрою та налаштувань платформи.
			Не весь контент доступний у високій роздільній здатності. Деталі про сумісність пристроїв та якість відтворення можна переглянути у
			<span class="underline underline-offset-4 cursor-pointer hover:text-white transition-colors">довідковому розділі</span>.
			Всі функції та можливості тарифного плану “<span class="underline underline-offset-4 cursor-pointer hover:text-white transition-colors">Стандарт</span>” автоматично включені у тариф
			“<span class="underline underline-offset-4 cursor-pointer hover:text-white transition-colors">Преміум</span>”.
		</p>
    </div>
    

</section>

<section class="w-full py-10">
	<div class="lumeo-container">
        <div class="mb-21">
            <h2 class="text-5xl font-bold text-white leading-tight">
                Сьогодні всі дивляться це
            </h2>
            <div class="mt-3 w-40 h-3 bg-[#D0F260]"></div>
        </div>

        <div class="flex gap-8">

            <div class="movie-card group">
                <img src="~/images/landing/posters/movie_1.png"
                     alt="Дикий робот"
                     class="movie-poster" />

                <span class="movie-rank-number">1</span>
            </div>

            <div class="movie-card group">
                <img src="~/images/landing/posters/movie_2.png"
                     alt="Відьмак"
                     class="movie-poster" />
                <span class="movie-rank-number">2</span>
            </div>

            <div class="movie-card group">
                <img src="~/images/landing/posters/movie_3.png"
                     alt="Дім дракона"
                     class="movie-poster" />
                <span class="movie-rank-number">3</span>
            </div>

            <div class="movie-card group">
                <img src="~/images/landing/posters/movie_4.png"
                     alt="Довга хода"
                     class="movie-poster" />
                <span class="movie-rank-number">4</span>
            </div>

            <div class="movie-card group">
                <img src="~/images/landing/posters/movie_5.png"
                     alt="Я не залізна"
                     class="movie-poster group-hover:scale-100" />

                <div class="absolute inset-0 rounded-3xl bg-gradient-to-r from-transparent via-[#22223A] via-70% to-[#22223A] z-10"></div>

                <span class="movie-rank-number">5</span>

                <button class="absolute right-7 top-1/2 -translate-y-1/2 w-17 h-15 bg-[#48485D] rounded-2xl flex items-center justify-center hover:bg-[#5a5a75] transition-colors z-30">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
            </div>

        </div>
    </div>
    
</section>

<section class="w-full relative pb-20">
    <div class="lumeo-container">
        <div class="pt-21 mb-21">
            <h2 class="text-5xl font-bold text-white leading-tight">
                Усі хіти від топ-студій в одному місці
            </h2>

            <div class="mt-3 w-40 h-3 bg-[#0059FF]"></div>

        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 xl:grid-cols-5">

            @foreach (var studio in Model.Studios)
            {
                <div class="studio-card">
                    <img src="@studio.StudioLogo" alt="@studio.StudioName" class="studio-logo" />
                </div>
            }
        </div>
    </div>

</section>

<section class="w-full relative py-21">

    <div class="lumeo-container mb-12">
        <h2 class="text-5xl font-bold text-white leading-tight">
            Все для тебе
        </h2>
        <div class="mt-4 w-40 h-3 bg-[#FF0000]"></div>
    </div>

    @{int i = 0; } <div class="lumeo-container grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 justify-items-center">
        @foreach (var feature in Model.Features)
        {
            <div class="feature-card group @(i == 3 ? "xl:col-start-2" : "")">
                <div class="pt-7 pl-5 pr-5">
                    <h3 class="font-black text-3xl text-white leading-tight mb-3">@feature.Title</h3>
                    <p class="font-normal text-xl text-white leading-tight max-w-lg">@feature.Description</p>
                </div>
                <img src="@feature.Icon" alt="screens" class="absolute bottom-6 right-14 w-16 h-16">    
            </div>
			i++;
        }

    </div>
</section>

<section class="w-full relative pt-12 pb-24">
    <div class="lumeo-container">

        <div class="mb-10">
            <h2 class="text-5xl font-bold text-white leading-tight">
                Є питання?
            </h2>
            <div class="mt-4 w-40 h-3 bg-[#EAC71B]"></div>
        </div>

        <div class="flex flex-col gap-6">

            @foreach (var question in Model.Questions)
            {
                <div class="faq-item group w-full rounded-3xl bg-[#3A3A61]/50 backdrop-blur-md border border-white/5 shadow-glass overflow-hidden transition-all duration-300">
                    <button onclick="toggleFaq(this)" class="w-full flex items-center justify-between p-8 text-left outline-none cursor-pointer">
                        <span class="font-semibold text-2xl text-white pl-1">
							@question.Question
                        </span>
                        <img src="~/images/ui/symbols/plus.svg" alt="Open"
                             class="faq-icon w-5 h-5 transition-transform duration-300">
                    </button>
                    <div class="faq-answer max-h-0 opacity-0 transition-all duration-500 ease-in-out">
                        <div class="px-9 pb-8 text-white/80 text-lg leading-relaxed">
							@question.Answer
						</div>
                    </div>
                </div>
            }

        </div>
    </div>
</section>

<script src="~/js/landing.js" asp-append-version="true"></script>
