@using StreamingService.DTO.Enums
@using StreamingService.Extensions
@model List<StreamingService.DTO.ViewModels.VideoCardViewModel>
@{
    Layout = "~/Views/Shared/Layouts/_LayoutApp.cshtml";

}

<section class="mt-8 mb-12 relative group">
    <div id="genresList" class="fade-mask-right flex items-center gap-5 overflow-x-auto custom-scrollbar-hide pr-56 snap-x scroll-smooth">
        @if (ViewBag.Genres != null)
        {
            @foreach (var genre in (List<StreamingService.DTO.ViewModels.GenreViewModel>)ViewBag.Genres)
            {
                <button data-genre-code="@genre.Code"
                        class="genre-btn snap-start flex-shrink-0 px-9 py-3 rounded-full bg-white/10 backdrop-blur-sm text-white font-medium text-base shadow-glass transition-all hover:bg-white/20 active:scale-95">
                    @genre.Name
                </button>
            }
        }
    </div>
    <div class="absolute right-0 top-1/2 -translate-y-1/2 z-20 flex items-center gap-2 pointer-events-none">
        <partial name="Partials/UI/_NavButton" model="@(new { Id = "genresLeftBtn", IsLeft = true, Theme = "glass" })" />
        <partial name="Partials/UI/_NavButton" model="@(new { Id = "genresRightBtn", IsLeft = false, Theme = "glass" })" />
    </div>
</section>


<section class="mb-16">
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-6 [&>div]:!w-full [&>div]:!max-w-none [&>div]:!min-w-0">

        @if (Model != null && Model.Any())
        {
            @foreach (var video in Model)
            {
                @await Component.InvokeAsync("VideoCard", video)
            }
        }
        else
        {
            <div class="col-span-full flex justify-center items-center py-20">
                <p class="text-white/50 text-xl font-montserrat">Тут поки порожньо. Додайте відео до улюблених!</p>
            </div>
        }

    </div>
</section>

@if (ViewBag.PostponedVideos != null && ((List<StreamingService.DTO.ViewModels.VideoCardViewModel>)ViewBag.PostponedVideos).Any())
{
    <div class="mt-16 mb-8 flex items-center gap-6">
        <h2 class="text-3xl font-bold text-white font-montserrat tracking-wide">Збережено на потім</h2>
        <div class="h-px bg-gradient-to-r from-white/20 to-transparent flex-1"></div>
    </div>

    <section id="saved-videos-section" class="mb-16">
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-6 [&>div]:!w-full [&>div]:!max-w-none [&>div]:!min-w-0">
            @foreach (var video in (List<StreamingService.DTO.ViewModels.VideoCardViewModel>)ViewBag.PostponedVideos)
            {
                @await Component.InvokeAsync("VideoCard", video)
            }
        </div>
    </section>
}



@section Scripts {
    <script src="~/js/video-carousel.js" asp-append-version="true"></script>
    <script src="~/js/genre-filter.js" asp-append-version="true"></script>
    <script src="~/js/favorites.js" asp-append-version="true"></script>
    <script src="~/js/save-for-later.js" asp-append-version="true"></script>
}