@model bool

<label class="relative flex items-center cursor-pointer mt-1 flex-shrink-0">
    <input type="checkbox" class="sr-only peer" @(Model ? "checked" : "")>

    <div class="w-12 h-6 bg-white/10 border border-white/20 rounded-full peer-checked:bg-[#D0F260]/50 peer-checked:border-[#D0F260] transition-colors duration-300"></div>
    <div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full transition-transform duration-300 peer-checked:translate-x-6 shadow-sm"></div>

    <svg class="absolute left-1 top-1 w-4 h-4 p-[2.5px] text-[#2C2C4C] opacity-0 peer-checked:opacity-100 transition-all duration-300 peer-checked:translate-x-6 z-10" fill="none" stroke="currentColor" stroke-width="4" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
    </svg>

    <svg class="absolute left-1 top-1 w-4 h-4 p-[2.5px] text-gray-500 opacity-100 peer-checked:opacity-0 transition-all duration-300 z-10" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
</label>