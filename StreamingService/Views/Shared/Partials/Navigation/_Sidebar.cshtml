@{
    var currentPath = Context.Request.Path.ToString().ToLower();
}

<div class="h-full flex flex-col py-6 overflow-y-auto custom-scrollbar overflow-x-hidden">

    <div class="px-4 lg:pl-16 lg:mt-8 mb-20 flex justify-center lg:justify-start">
        <a href="/" class="block hover:opacity-80 transition-opacity">
            <img src="/images/ui/Lumeo_logo.svg" alt="Lumeo" class="h-8 w-auto hidden lg:block" />
            <div class="lg:hidden w-8 h-8 overflow-hidden relative">
                <img src="/images/ui/Lumeo_logo.svg" alt="Lumeo" class="h-8 w-auto absolute left-0 max-w-none" />
            </div>
        </a>
    </div>

    @await Component.InvokeAsync("Sidebar")

    <div class="px-4 lg:pl-16 lg:pr-16 mt-auto hidden lg:block">
        
        <div class="flex items-center gap-5 mb-4 group cursor-default">
            
            <div class="w-8 h-8 flex items-center justify-center flex-shrink-0">
                <img src="/images/ui/sidebar/continue.png" 
                     alt="Continue" 
                     class="w-full h-full object-contain opacity-50 group-hover:opacity-100 transition-opacity duration-300" />
            </div>

            <span class="text-xl font-montserrat font-medium leading-none text-white/50 group-hover:text-white transition-colors">
                Продовжити перегляд
            </span>
        </div>
        
        <div class="relative w-full aspect-video rounded-2xl overflow-hidden group cursor-pointer border border-white/5 hover:border-[#DCF260] transition-all">
            <img src="/images/landing/Landing_revenant.png" alt="Movie" class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity" />

            <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-10 h-10 rounded-full bg-[#DCF260]/90 flex items-center justify-center shadow-[0_0_15px_#DCF260] scale-75 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-300">
                    <svg class="w-4 h-4 text-black ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
                </div>
            </div>

            <div class="absolute bottom-0 left-0 w-full h-1 bg-white/20">
                <div class="h-full bg-[#DCF260] w-2/3 shadow-[0_0_10px_#DCF260]"></div>
            </div>
        </div>

        <div class="mt-2 px-1">
            <div class="text-sm font-bold text-white truncate">Легенда Г'ю Гласса</div>
            <div class="text-xs text-white/40">1г 24хв залишилось</div>
        </div>
    </div>

</div>