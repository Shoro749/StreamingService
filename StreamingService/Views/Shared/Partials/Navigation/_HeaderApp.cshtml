@using StreamingService.DTO.Enums
@using StreamingService.Extensions
@{
	var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = currentController == "Home"
        ? (ViewContext.RouteData.Values["action"]?.ToString() ?? "Catalog")
        : "Catalog";
}

<div class="flex items-center w-full h-16 gap-4">

    <div class="relative z-50">

        <button id="menuBtn"
                style="background-image: url('/images/ui/dropdownMenuBtn/bg-@(ViewData["Category"] ?? "All").png'); background-size: cover; background-position: center;"
                class="shadow-glass flex-shrink-0 flex items-center justify-center gap-6 w-40 h-16 bg-white/10 rounded-xl backdrop-blur-sm cursor-pointer hover:bg-white/20 transition-all">

            <span class="font-medium text-xl text-white" id="currentCategory">
                @ViewData["MenuTitle"]
            </span>

            <svg id="menuArrow" class="w-3 h-2 text-white transition-transform duration-300" viewBox="0 0 13 7" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1L6.5 6L12 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </button>

        <div id="dropdownMenu"
             class="hidden absolute top-full left-0 mt-2 w-48 py-2 bg-white/10 backdrop-blur-xl border border-white/10 rounded-xl shadow-glass overflow-hidden transition-all origin-top">

            <ul class="flex flex-col">
                <li>
                    <a asp-controller="Home"
                       asp-action="@currentAction"
                       class="block px-6 py-3 text-white hover:bg-white/20 transition-colors"
                       data-bg="bg-neutral">
                        Усі
                    </a>
                </li>

                @foreach (VideoType category in Enum.GetValues(typeof(VideoType)))
                {
                    <li>
                        <a asp-controller="Home"
                           asp-action="@currentAction"
						   asp-route-category="@category"
                           class="block px-6 py-3 text-white hover:bg-white/20 transition-colors"
                           data-bg="bg-@category">
                            @category.GetDisplayName()
                        </a>
                    </li>
                }
            </ul>
        </div>

    </div>

    <div class="shadow-glass hidden xl:flex items-center gap-4 bg-white/10 rounded-xl pl-8 pr-0 h-16 backdrop-blur-sm transition-colors focus-within:bg-white/20 flex-1 max-w-4xl overflow-hidden">

        <img src="/images/ui/symbols/search.svg"
             class="w-7 h-7 opacity-50 flex-shrink-0"
             alt="Search">

        <input type="text"
               placeholder="Фільми, серіали"
               class="bg-transparent border-none outline-none focus:ring-0 w-full text-xl font-medium leading-none text-white placeholder-white/50 h-full p-0" />

        <div class="flex items-center h-full">
            <div class="h-13 w-px bg-white/30"></div>
            <button class="w-18 h-full flex items-center justify-center hover:bg-white/10 transition-colors group/filter">
                <img src="/images/ui/symbols/search_filters.svg"
                     class="w-6 h-6 opacity-80 group-hover/filter:opacity-100 transition-opacity"
                     alt="Filters">
            </button>
        </div>
    </div>

    <div class="flex items-center gap-4 ml-auto">

        <button class="shadow-glass w-16 h-16 bg-white/10 rounded-xl backdrop-blur-sm flex items-center justify-center hover:bg-white/20 transition-all relative">
            <img src="/images/ui/symbols/bell.svg" class="w-6 h-6 opacity-70" alt="Notification">
        </button>

        <div class="shadow-glass flex items-center gap-6 px-5 w-auto md:max-w-56 h-16 bg-white/10 rounded-xl backdrop-blur-sm cursor-pointer hover:bg-white/20 transition-all group">

            <img src="https://ui-avatars.com/api/?name=Maria+W&background=random&color=fff"
                    class="w-9 h-9 rounded-xl object-cover flex-shrink-0" alt="Avatar">

            <div class="hidden md:flex flex-col overflow-hidden">
                <span class="font-medium text-lg leading-tight text-white truncate">Maria W.</span>
                <span class="font-semibold text-base leading-tight text-[#DCF260]">Преміум</span>
            </div>

            <svg class="hidden md:block w-3 h-2 text-white ml-auto transition-transform group-hover:rotate-180 flex-shrink-0" viewBox="0 0 13 7" fill="none">
                <path d="M1 1L6.5 6L12 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>

    </div>

</div>
