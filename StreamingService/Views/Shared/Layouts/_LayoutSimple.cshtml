<!DOCTYPE html>
<html lang="uk">
<head>
    <partial name="~/Views/Shared/Partials/Base/_Head.cshtml" />
</head>
<body class="bg-[#22223A] text-white font-sans antialiased min-h-screen flex flex-col relative overflow-x-hidden selection:bg-[#DCF260] selection:text-black">

    

    <div class="relative z-10 flex flex-col min-h-screen">

        <main class="flex-1 flex flex-col items-center justify-center w-full">
            @RenderBody()
        </main>
        <partial name="~/Views/Shared/Partials/Base/_BottomBanner.cshtml" />
        <partial name="~/Views/Shared/Partials/Navigation/_Footer.cshtml" />

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/auth.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>