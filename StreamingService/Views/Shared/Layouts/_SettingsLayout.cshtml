@{
    var activeTab = ViewBag.ActiveTab as string;
    string GetTabClass(string tabName)
    {
        return activeTab == tabName
        ? "flex items-center w-full px-6 py-1 text-[#D0F260] font-montserrat font-medium text-lg border-r-2 border-[#D0F260] transition-colors"
        : "flex items-center w-full px-6 py-1 text-[#D3D3D3] font-montserrat font-medium text-lg hover:text-white transition-colors";
    }
    Layout = "~/Views/Shared/Layouts/_LayoutApp.cshtml";
}

<div class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-none p-4 sm:p-8 pt-20">

    <div class="w-full max-w-6xl h-[85vh] bg-[#2C2C4C] rounded-3xl flex overflow-hidden relative shadow-2xl">

        <a href="@ViewBag.ReturnUrl" class="absolute top-6 right-6 text-white transition-colors z-50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </a>

        <aside class="w-104 flex-shrink-0 bg-[#22223A] overflow-y-auto custom-scrollbar-hide py-8 relative shadow-2xl z-10">

            <div class="px-6 mb-10">
                <div class="shadow-glass relative flex items-center w-full h-12 bg-white/10 rounded-2xl px-5">
                    <svg class="w-6 h-6 text-white/50 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <input type="text" placeholder="Пошук" class="w-full bg-transparent text-xl text-white placeholder-white/50 focus:outline-none font-medium">
                </div>
            </div>

            <div class="mb-8">
                <h3 class="px-6 mb-3 text-base font-extrabold text-white uppercase tracking-wider">Налаштування користувача</h3>
                <nav class="flex flex-col">
                    <a href="/settings/profile?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("profile")">Мій обліковий запис</a>
                    <a href="/settings/privacy?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("privacy")">Конфіденційність і дані</a>
                    <a href="/settings/devices?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("devices")">Підключені пристрої</a>
                    <a href="/settings/history?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("history")">Історія переглядів</a>
                    <a href="/settings/integrations?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("integrations")">Інтеграції</a>
                </nav>
            </div>

            <div class="mb-8">
                <h3 class="px-6 mb-3 text-base font-extrabold text-white uppercase tracking-wider">Підписка і оплата</h3>
                <nav class="flex flex-col">
                    <a href="/settings/plans?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("plans")">Тарифні плани</a>
                    <a href="/settings/subscriptions?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("subscriptions")">Підписки</a>
                    <a href="/settings/payment-methods?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("payment-methods")">Спосіб оплати</a>
                    <a href="/settings/gift-cards?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("gift-cards")">Подарункові сертифікати</a>
                </nav>
            </div>

            <div class="mb-2">
                <h3 class="px-6 mb-3 text-base font-extrabold text-white uppercase tracking-wider">Налаштування сайту</h3>
                <nav class="flex flex-col">
                    <a href="/settings/notifications?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("notifications")">Сповіщення</a>
                    <a href="/settings/language?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("language")">Мова</a>
                    <a href="/settings/playback?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("playback")">Звук і відео</a>
                    <a href="/settings/accessibility?returnUrl=@ViewBag.ReturnUrl" class="@GetTabClass("accessibility")">Доступність</a>
                </nav>
            </div>
        </aside>

        <main class="flex-1 overflow-y-auto custom-scrollbar-hide p-8 relative">
            <h1 class="text-2xl font-bold text-white mb-6">@ViewData["Title"]</h1>
            @RenderBody()
        </main>

    </div>
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}