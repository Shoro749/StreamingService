@{
    var backdropUrl = ViewData["FullscreenBackdrop"] as string;
    var bodyStyle = !string.IsNullOrEmpty(backdropUrl)
        ? $"background-image: linear-gradient(rgba(0,0,0, 0.3), rgba(0,0,0, 0.3)), url('{backdropUrl}');"
        : "";
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <partial name="~/Views/Shared/Partials/Base/_Head.cshtml" />
</head>
<body class="text-white font-sans antialiased overflow-hidden selection:bg-[#DCF260] selection:text-black bg-cover bg-center bg-no-repeat" 
      style="@bodyStyle">

    <div class="flex h-screen w-full overflow-hidden">

        <aside class="w-20 lg:w-84 flex-shrink-0 flex flex-col z-50 relative transition-all duration-300">
            <partial name="~/Views/Shared/Partials/Navigation/_Sidebar.cshtml" />
        </aside>

        <div class="flex-1 flex flex-col min-w-0 relative">

            <header class="flex-shrink-0 z-40 px-6 md:px-12 pt-10 pb-4">
                <partial name="~/Views/Shared/Partials/Navigation/_HeaderApp.cshtml" />
            </header>

            <main class="flex-1 p-0 relative flex flex-col">
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="~/js/ui-components.js" asp-append-version="true"></script>
    <script src="~/js/carousel-modal.js" asp-append-version="true"></script>
    <script src="~/js/favorites.js" asp-append-version="true"></script>
    <script src="~/js/dropdown-menu.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>