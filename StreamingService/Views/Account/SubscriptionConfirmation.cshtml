@model StreamingService.DTO.ViewModels.AgreementViewModel
@{
    Layout = "~/Views/Shared/Layouts/_LayoutSimple.cshtml";
    ViewData["Title"] = "Оплата підписки";
}

<div class="relative min-h-screen w-full overflow-hidden flex items-center justify-center p-4">

    <partial name="~/Views/Shared/Partials/Auth/_AuthBackgroundText.cshtml"
             model="Model.BackgroundText" />

    <div class="relative z-10 w-full max-w-screen-md bg-[#9A9A9A]/10 backdrop-blur-xs border border-white/5 shadow-glass rounded-3xl p-8 md:p-12 flex flex-col gap-10">

        <div class="flex flex-col gap-6 text-center md:text-left">
            <h2 class="font-bold text-4xl md:text-5xl text-white">Крок 2 з 3</h2>
            <p class="font-montserrat font-normal text-lg md:text-xl leading-tight text-white">
                Підтвердьте свою підписку <br />
                <span>Lumeo @Model.SubscriptionPlan — @Model.SubscriptionPrice грн / місяць</span>
            </p>
            <p class="font-montserrat font-normal text-lg text-[#D3D3D3] -mt-2">
                Підписку можна скасувати будь-коли. Вона діє до кінця оплаченого періоду.
            </p>
        </div>

        <form asp-controller="Subscription" asp-action="ProcessPayment" method="post" class="flex flex-col gap-8">

            @* ПРИХОВАНЕ ПОЛЕ *@
            <input type="hidden" id="selectedPaymentMethod" name="PaymentMethod" value="Card" />
            <input type="hidden" id="subscriptionPlan" name="plan" value=@(Model.SubscriptionPlan) />

            @* ВКЛАДКИ (Tabs) *@
            <div class="flex items-end justify-between border-b border-white pb-0 mb-2">

                @* 1. КАРТКА (Активна) *@
                <button type="button" data-target="payment-card" class="tab-button group flex flex-col items-center gap-1 text-[#D0F260] border-b-4 border-[#D0F260] pb-2 -mb-[2px] px-4 transition-all cursor-pointer">
                    <img src="~/images/ui/payments/card.svg" alt="Card" class="tab-icon w-11 h-11 object-contain transition-all duration-300" />
                    <span class="font-montserrat font-normal text-xs md:text-sm text-center">Кредитна / Дебетова картка</span>
                </button>

                @* 2. PAYPAL *@
                <button type="button" data-target="payment-paypal" class="tab-button group flex flex-col items-center gap-1 text-white border-b-2 border-transparent hover:text-white pb-2 -mb-[1px] px-2 transition-all cursor-pointer opacity-50 hover:opacity-100">
                    <img src="~/images/ui/payments/paypal.svg" alt="PayPal" class="tab-icon w-11 h-11 object-contain transition-all duration-300 brightness-0 invert" />
                    <span class="font-montserrat font-normal text-xs md:text-sm text-center">PayPal</span>
                </button>

                @* 3. GOOGLE PAY *@
                <button type="button" data-target="payment-googlepay" class="tab-button group flex flex-col items-center gap-1 text-white border-b-2 border-transparent hover:text-white pb-2 -mb-[1px] px-2 transition-all cursor-pointer opacity-50 hover:opacity-100">
                    <img src="~/images/ui/payments/googlepay.svg" alt="GooglePay" class="tab-icon w-11 h-11 object-contain transition-all duration-300 brightness-0 invert" />
                    <span class="font-montserrat font-normal text-xs md:text-sm text-center">Google Pay</span>
                </button>

                @* 4. APPLE PAY *@
                <button type="button" data-target="payment-applepay" class="tab-button group flex flex-col items-center gap-1 text-white border-b-2 border-transparent hover:text-white pb-2 -mb-[1px] px-2 transition-all cursor-pointer opacity-50 hover:opacity-100">
                    <img src="~/images/ui/payments/applepay.svg" alt="ApplePay" class="tab-icon w-11 h-11 object-contain transition-all duration-300 brightness-0 invert" />
                    <span class="font-montserrat font-normal text-xs md:text-sm text-center">Apple Pay</span>
                </button>
            </div>

            @* ВМІСТ: КАРТКА *@
            <div id="payment-card" class="payment-content flex flex-col gap-8">
                <div class="flex flex-col gap-2.5">
                    <label class="font-montserrat font-medium text-base text-white">Ім'я на картці</label>
                    <input type="text" placeholder="TARAS SHEVCHENKO" class="shadow-glass w-full h-16 bg-[#9A9A9A]/10 rounded-2xl px-6 text-white font-montserrat text-base placeholder:text-white/20 focus:outline-none focus:ring-2 focus:ring-[#D0F260] transition-all uppercase" />
                </div>
                <div class="flex flex-col gap-2.5 relative">
                    <label class="font-montserrat font-medium text-base text-white">Номер картки</label>
                    <div class="relative">
                        <input type="text" placeholder="0000 0000 0000 0000" class="shadow-glass w-full h-16 bg-[#9A9A9A]/10 rounded-2xl px-6 text-white font-montserrat text-base placeholder:text-white/20 focus:outline-none focus:ring-2 focus:ring-[#D0F260] transition-all tracking-widest" />
                        <div class="absolute right-6 top-1/2 -translate-y-1/2 flex gap-2 opacity-70">
                            <img src="~/images/ui/payments/visa.svg" alt="Visa" class="h-4 w-auto object-contain" />
                            <img src="~/images/ui/payments/master.svg" alt="Mastercard" class="h-4 w-auto object-contain" />
                        </div>
                    </div>
                </div>
                <div class="flex flex-col md:flex-row gap-4 md:gap-2.5">
                    <div class="flex flex-col gap-2.5 w-full md:w-1/2">
                        <label class="font-montserrat font-medium text-base text-white">Термін дії (MM/YY)</label>
						<input type="text" 
                               name="card-expiry"
							   autocomplete="cc-exp"
                               placeholder="MM / YY"
                               class="shadow-glass w-full h-16 bg-[#9A9A9A]/10 rounded-2xl px-6 text-white font-montserrat text-base placeholder:text-white/20 focus:outline-none focus:ring-2 focus:ring-[#D0F260] transition-all text-center" />
                    </div>

                    <div class="flex flex-col gap-2.5 w-full md:w-1/2">
                        <label class="font-montserrat font-medium text-base text-white">CVV код</label>
                        <input type="password" 
                               name="card-cvc" 
                               autocomplete="cc-csc" 
                               placeholder="***" 
                               class="shadow-glass w-full h-16 bg-[#9A9A9A]/10 rounded-2xl px-6 text-white font-montserrat text-base placeholder:text-white/20 focus:outline-none focus:ring-2 focus:ring-[#D0F260] transition-all text-center tracking-widest" />
                    </div>
                </div>
                <div class="flex items-center gap-3 mt-2">
                    <input type="checkbox" id="saveCard" class="w-5 h-5 rounded bg-[#9A9A9A]/10 border-white/20 text-[#D0F260] shadow-glass focus:ring-0 focus:ring-offset-0 checked:bg-[#D0F260] cursor-pointer" />
                    <label for="saveCard" class="font-montserrat text-sm text-white/70 cursor-pointer select-none">
                        Зберегти платіжну інформацію для майбутніх покупок. <a href="#" class="underline hover:text-white">Дізнатися більше</a>
                    </label>
                </div>
            </div>

            @* ВМІСТ: ІНШІ МЕТОДИ *@
            <div id="payment-paypal" class="payment-content hidden flex flex-col items-center justify-center gap-6 py-10">
                <div class="text-center space-y-2">
                    <p class="font-montserrat text-xl text-white">Оплата через PayPal</p>
                    <p class="font-montserrat text-sm text-white/60">Для оплати ви будете перенаправлені на сервіс PayPal.</p>
                </div>
            </div>
            <div id="payment-googlepay" class="payment-content hidden flex flex-col items-center justify-center gap-6 py-10">
                <p class="font-montserrat text-sm text-white/60">Швидка оплата через Google Pay</p>
            </div>
            <div id="payment-applepay" class="payment-content hidden flex flex-col items-center justify-center gap-6 py-10">
                <p class="font-montserrat text-sm text-white/60">Підтвердіть оплату через Apple Pay</p>
            </div>

            @* КНОПКА *@
            <button type="submit"
                    id="submitButton"
                    class="w-full md:w-auto md:self-center h-14 bg-[#D0F260] text-[#22223A] font-black text-xl md:text-2xl uppercase rounded-xl shadow-[0px_2px_81px_rgba(208,242,96,0.2)] hover:bg-white hover:scale-105 transition-all duration-300 flex items-center justify-center cursor-pointer px-12">
                Підтвердити та почати перегляд
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/payment-method.js" asp-append-version="true"></script>
}